def is_eligible(cgpa, backlogs, projects, branch):
          # cgpa = 8.5
          # backlogs = 0
          # projects = 3

          if cgpa >= 7.0 and backlogs == 0 and cgpa >= 6.5 and projects >= 3:
                    if branch in {"Computer Science", 'IT'}:
                          return "Eligible for placements"
                    return "Your not eligible for placements"
print(is_eligible(9.0, 0, 5, "Computer Science"))
print(is_eligible(9.0, 0, 3, "Mechanical"))
print(is_eligible(9.0, 0, 1, "Civil"))
print(is_eligible(9.0, 0, 3, "IT"))